#!/usr/bin/env python3
"""hypr-snap-gui: post-recording popup for hypr-snap"""

import gi

gi.require_version("Gdk", "4.0")
gi.require_version("Gtk", "4.0")

from gi.repository import Gdk, Gio, GLib, Gtk
import json
import os
import subprocess
import sys
import threading

CSS = """
window {
    background-color: #1e1e2e;
}
.snap-filename {
    color: #cdd6f4;
    font-weight: 600;
    font-size: 14px;
}
.snap-info {
    color: #6c7086;
    font-size: 12px;
}
.snap-trim-display {
    color: #89b4fa;
    font-size: 13px;
    font-family: monospace;
}
.snap-status-success {
    color: #a6e3a1;
    font-size: 12px;
}
.snap-status-error {
    color: #f38ba8;
    font-size: 12px;
}
.snap-button {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 10px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 500;
    min-height: 20px;
}
.snap-button:hover {
    background-color: #45475a;
}
.snap-button-trim {
    background-color: rgba(137, 180, 250, 0.1);
    color: #89b4fa;
}
.snap-button-trim:hover {
    background-color: rgba(137, 180, 250, 0.18);
}
.snap-button-gif {
    background-color: rgba(166, 227, 161, 0.1);
    color: #a6e3a1;
}
.snap-button-gif:hover {
    background-color: rgba(166, 227, 161, 0.18);
}
.snap-button-delete {
    background-color: rgba(243, 139, 168, 0.1);
    color: #f38ba8;
}
.snap-button-delete:hover {
    background-color: rgba(243, 139, 168, 0.18);
}
"""


def format_time(seconds):
    m = int(seconds) // 60
    s = seconds - (m * 60)
    return f"{m}:{s:04.1f}"


def format_size(nbytes):
    if nbytes >= 1048576:
        return f"{nbytes / 1048576:.1f} MB"
    return f"{nbytes / 1024:.0f} KB"


class SnapWindow(Gtk.ApplicationWindow):
    def __init__(self, app, video_path):
        super().__init__(application=app, title="hypr-snap")
        self.video_path = video_path
        self.gif_path = None
        self._converting = False
        self._trimming = False
        self._trim_start = 0.0
        self._trim_end = None
        self._duration = 0.0
        self._config = self._load_config()

        self.set_default_size(640, -1)

        provider = Gtk.CssProvider()
        provider.load_from_string(CSS)
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(),
            provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

        key_ctrl = Gtk.EventControllerKey()
        key_ctrl.connect("key-pressed", self._on_key)
        self.add_controller(key_ctrl)

        self._build_ui()

    def _get_video_info(self):
        info = {"duration": 0, "width": 0, "height": 0, "size": 0}
        try:
            info["size"] = os.path.getsize(self.video_path)
        except OSError:
            pass
        try:
            result = subprocess.run(
                [
                    "ffprobe", "-v", "quiet", "-print_format", "json",
                    "-show_format", "-show_streams", self.video_path,
                ],
                capture_output=True,
                text=True,
                timeout=10,
            )
            data = json.loads(result.stdout)
            if "format" in data:
                info["duration"] = float(data["format"].get("duration", 0))
            for stream in data.get("streams", []):
                if stream.get("codec_type") == "video":
                    info["width"] = int(stream.get("width", 0))
                    info["height"] = int(stream.get("height", 0))
                    break
        except Exception:
            pass
        return info

    def _refresh_info(self):
        info = self._get_video_info()
        self._duration = info["duration"]
        self._update_info_label(info)

    def _build_ui(self):
        info = self._get_video_info()
        self._duration = info["duration"]
        self._trim_end = self._duration

        main = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        main.set_margin_top(12)
        main.set_margin_bottom(12)
        main.set_margin_start(12)
        main.set_margin_end(12)

        # Video player
        self._video = Gtk.Video.new_for_filename(self.video_path)
        self._video.set_autoplay(True)
        self._video.set_loop(True)
        main.append(self._video)

        # File info
        info_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)

        name_label = Gtk.Label(label=os.path.basename(self.video_path))
        name_label.set_halign(Gtk.Align.START)
        name_label.add_css_class("snap-filename")
        info_box.append(name_label)

        self._info_label = Gtk.Label()
        self._info_label.set_halign(Gtk.Align.START)
        self._info_label.add_css_class("snap-info")
        self._update_info_label(info)
        info_box.append(self._info_label)

        main.append(info_box)

        # Trim controls
        trim_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        trim_box.set_valign(Gtk.Align.CENTER)

        mark_in_btn = Gtk.Button(label="Mark In")
        mark_in_btn.add_css_class("snap-button")
        mark_in_btn.add_css_class("snap-button-trim")
        mark_in_btn.connect("clicked", self._on_mark_in)
        trim_box.append(mark_in_btn)

        self._trim_label = Gtk.Label(
            label=f"{format_time(0)} \u2192 {format_time(self._duration)}"
        )
        self._trim_label.add_css_class("snap-trim-display")
        self._trim_label.set_hexpand(True)
        trim_box.append(self._trim_label)

        mark_out_btn = Gtk.Button(label="Mark Out")
        mark_out_btn.add_css_class("snap-button")
        mark_out_btn.add_css_class("snap-button-trim")
        mark_out_btn.connect("clicked", self._on_mark_out)
        trim_box.append(mark_out_btn)

        self._trim_btn = Gtk.Button(label="Trim")
        self._trim_btn.add_css_class("snap-button")
        self._trim_btn.add_css_class("snap-button-trim")
        self._trim_btn.connect("clicked", self._on_trim)
        self._trim_btn.set_sensitive(False)
        trim_box.append(self._trim_btn)

        main.append(trim_box)

        # Status label
        self._status = Gtk.Label()
        self._status.set_halign(Gtk.Align.START)
        self._status.set_visible(False)
        main.append(self._status)

        # Action buttons
        btns = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)

        copy_btn = Gtk.Button(label="Copy Path")
        copy_btn.add_css_class("snap-button")
        copy_btn.connect("clicked", self._on_copy)
        btns.append(copy_btn)

        self._gif_btn = Gtk.Button(label="GIF")
        self._gif_btn.add_css_class("snap-button")
        self._gif_btn.add_css_class("snap-button-gif")
        self._gif_btn.connect("clicked", self._on_gif)
        btns.append(self._gif_btn)

        open_btn = Gtk.Button(label="Open")
        open_btn.add_css_class("snap-button")
        open_btn.connect("clicked", self._on_open)
        btns.append(open_btn)

        spacer = Gtk.Box()
        spacer.set_hexpand(True)
        btns.append(spacer)

        del_btn = Gtk.Button(label="Delete")
        del_btn.add_css_class("snap-button")
        del_btn.add_css_class("snap-button-delete")
        del_btn.connect("clicked", self._on_delete)
        btns.append(del_btn)

        main.append(btns)
        self.set_child(main)

    def _update_info_label(self, info):
        parts = []
        if info["duration"] > 0:
            parts.append(f"{info['duration']:.1f}s")
        if info["size"] > 0:
            parts.append(format_size(info["size"]))
        if info["width"] > 0:
            parts.append(f"{info['width']}\u00d7{info['height']}")
        self._info_label.set_text(" \u00b7 ".join(parts) if parts else "")

    def _get_playback_position(self):
        stream = self._video.get_media_stream()
        if stream:
            return stream.get_timestamp() / 1_000_000
        return 0.0

    def _update_trim_display(self):
        end = self._trim_end if self._trim_end is not None else self._duration
        self._trim_label.set_text(
            f"{format_time(self._trim_start)} \u2192 {format_time(end)}"
        )
        modified = (
            self._trim_start > 0.1
            or (self._trim_end is not None and self._trim_end < self._duration - 0.1)
        )
        self._trim_btn.set_sensitive(modified and not self._trimming)

    def _on_mark_in(self, _btn):
        pos = self._get_playback_position()
        self._trim_start = pos
        self._update_trim_display()
        self._set_status(f"Start marked at {format_time(pos)}")

    def _on_mark_out(self, _btn):
        pos = self._get_playback_position()
        self._trim_end = pos
        self._update_trim_display()
        self._set_status(f"End marked at {format_time(pos)}")

    def _on_trim(self, _btn):
        if self._trimming:
            return
        self._trimming = True
        self._trim_btn.set_label("Trimming...")
        self._trim_btn.set_sensitive(False)

        start = self._trim_start
        end = self._trim_end if self._trim_end is not None else self._duration
        trimmed = os.path.splitext(self.video_path)[0] + "_trimmed.mp4"

        def do_trim():
            try:
                subprocess.run(
                    [
                        "ffmpeg", "-y", "-ss", str(start), "-to", str(end),
                        "-i", self.video_path, "-c", "copy", trimmed,
                    ],
                    capture_output=True,
                    timeout=120,
                    check=True,
                )
                GLib.idle_add(self._trim_done, trimmed, None)
            except Exception as e:
                GLib.idle_add(self._trim_done, trimmed, str(e))

        threading.Thread(target=do_trim, daemon=True).start()

    def _trim_done(self, trimmed_path, error):
        self._trimming = False
        self._trim_btn.set_label("Trim")
        if error or not os.path.exists(trimmed_path):
            self._trim_btn.set_sensitive(True)
            self._set_status("Trim failed", success=False)
        else:
            self._video.set_file(None)
            os.replace(trimmed_path, self.video_path)
            self._video.set_file(Gio.File.new_for_path(self.video_path))
            self._video.set_autoplay(True)
            self._video.set_loop(True)
            self._trim_start = 0.0
            self._refresh_info()
            self._trim_end = self._duration
            self._update_trim_display()
            self.gif_path = None
            self._gif_btn.set_label("GIF")
            self._set_status("Trimmed successfully")
        return False

    def _set_status(self, text, success=True):
        self._status.set_text(text)
        for cls in ("snap-status-success", "snap-status-error"):
            self._status.remove_css_class(cls)
        self._status.add_css_class(
            "snap-status-success" if success else "snap-status-error"
        )
        self._status.set_visible(True)

        def _hide():
            self._status.set_visible(False)
            return GLib.SOURCE_REMOVE

        GLib.timeout_add(4000, _hide)

    def _on_copy(self, _btn):
        subprocess.run(["wl-copy", self.video_path], check=False)
        self._set_status("Path copied to clipboard")

    def _on_gif(self, _btn):
        if self._converting:
            return
        if self.gif_path and os.path.exists(self.gif_path):
            subprocess.run(["wl-copy", self.gif_path], check=False)
            self._set_status("GIF path copied to clipboard")
            return

        self._converting = True
        self._gif_btn.set_label("Converting...")
        self._gif_btn.set_sensitive(False)

        gif_path = os.path.splitext(self.video_path)[0] + ".gif"
        gif_fps = self._config.get("GIF_FPS", "15")
        gif_width = self._config.get("GIF_MAX_WIDTH", "640")

        def convert():
            try:
                subprocess.run(
                    [
                        "ffmpeg", "-y", "-i", self.video_path,
                        "-filter_complex",
                        f"fps={gif_fps},"
                        f"scale='min({gif_width},iw)':-1:flags=lanczos,"
                        f"split[s0][s1];[s0]palettegen[p];[s1][p]paletteuse",
                        "-loop", "0", gif_path,
                    ],
                    capture_output=True,
                    timeout=300,
                    check=True,
                )
                GLib.idle_add(self._gif_done, gif_path, None)
            except Exception as e:
                GLib.idle_add(self._gif_done, gif_path, str(e))

        threading.Thread(target=convert, daemon=True).start()

    def _gif_done(self, gif_path, error):
        self._converting = False
        self._gif_btn.set_sensitive(True)
        if error or not os.path.exists(gif_path):
            self._gif_btn.set_label("GIF")
            self._set_status("GIF conversion failed", success=False)
        else:
            self.gif_path = gif_path
            self._gif_btn.set_label("Copy GIF")
            subprocess.run(["wl-copy", gif_path], check=False)
            self._set_status(
                f"GIF saved ({format_size(os.path.getsize(gif_path))}) - path copied"
            )
        return False

    @staticmethod
    def _load_config():
        config = {}
        path = os.path.join(
            os.environ.get("XDG_CONFIG_HOME", os.path.expanduser("~/.config")),
            "hypr-snap",
            "config",
        )
        try:
            with open(path) as f:
                for line in f:
                    line = line.strip()
                    if line and not line.startswith("#") and "=" in line:
                        k, _, v = line.partition("=")
                        config[k.strip()] = v.strip().strip("\"'")
        except FileNotFoundError:
            pass
        return config

    def _on_open(self, _btn):
        subprocess.Popen(["xdg-open", os.path.dirname(self.video_path)])

    def _on_delete(self, _btn):
        for path in (self.video_path, self.gif_path):
            if path:
                try:
                    os.unlink(path)
                except OSError:
                    pass
        self.close()

    def _on_key(self, _ctrl, keyval, _keycode, _state):
        if keyval == Gdk.KEY_Escape:
            self.close()
            return True
        return False


def main():
    if len(sys.argv) != 2:
        print(f"Usage: {sys.argv[0]} <video-file>", file=sys.stderr)
        sys.exit(1)

    path = os.path.abspath(sys.argv[1])
    if not os.path.exists(path):
        print(f"File not found: {path}", file=sys.stderr)
        sys.exit(1)

    app = Gtk.Application(
        application_id="dev.kloogans.hypr-snap",
        flags=Gio.ApplicationFlags.NON_UNIQUE,
    )
    app.connect("activate", lambda a: SnapWindow(a, path).present())
    app.run([])


if __name__ == "__main__":
    main()
